{"ast":null,"code":"import { generateWordDocument } from '@/utils/docGenerator';\nexport default {\n  name: 'DocumentView',\n  data() {\n    return {\n      headerConfig: {\n        codigo: 'PP-P-PROV-001',\n        area: 'Administración y Finanzas',\n        unidad: 'Tesorería',\n        revision: '(1)'\n      },\n      sections: [\n        // ... (las secciones se mantienen igual)\n      ],\n      procedureTable: [{\n        number: '',\n        who: '',\n        activity: 'Pagos de Compras de Crédito'\n      }],\n      statusMessage: '',\n      statusType: ''\n    };\n  },\n  methods: {\n    generateWordDocument() {\n      const documentData = {\n        headerConfig: this.headerConfig,\n        objetivo: this.sections[0].content,\n        alcance: this.sections[1].content,\n        responsabilidades: this.sections[2].content,\n        normativa: this.sections[3].content,\n        anexos: this.sections[4].content,\n        terminos: this.sections[5].content,\n        nota: 'Documento generado automáticamente - ASADOS EL CARRETÓN'\n      };\n      try {\n        generateWordDocument(documentData, this.procedureTable);\n        this.showStatus('✅ Documento Word generado exitosamente!', 'success');\n      } catch (error) {\n        this.showStatus('❌ Error al generar el documento: ' + error.message, 'error');\n      }\n    }\n    // ... (los demás métodos se mantienen igual)\n  }\n};","map":{"version":3,"names":["generateWordDocument","name","data","headerConfig","codigo","area","unidad","revision","sections","procedureTable","number","who","activity","statusMessage","statusType","methods","documentData","objetivo","content","alcance","responsabilidades","normativa","anexos","terminos","nota","showStatus","error","message"],"sources":["/home/jorge/Escritorio/Jorge-PC/procesos/procesos/src/views/DocumentView.vue"],"sourcesContent":["<template>\n  <div class=\"document-view\">\n    <div class=\"document-controls\">\n      <button @click=\"generateWordDocument\" class=\"generate-btn\">\n        📄 Generar Documento Word\n      </button>\n      <button @click=\"loadOriginalContent\" class=\"sample-btn\">\n        🎯 Cargar Contenido Original\n      </button>\n      <button @click=\"resetDocument\" class=\"reset-btn\">\n        🔄 Limpiar Todo\n      </button>\n    </div>\n\n    <div class=\"status-message\" v-if=\"statusMessage\" :class=\"statusType\">\n      {{ statusMessage }}\n    </div>\n\n    <div class=\"document-editor\">\n      <!-- Configuración del Encabezado -->\n      <div class=\"section header-config\">\n        <h3>📋 Configuración del Encabezado del Documento</h3>\n        <div class=\"header-fields\">\n          <div class=\"field-group\">\n            <label>Código del Documento:</label>\n            <input v-model=\"headerConfig.codigo\" placeholder=\"PP-P-PROV-001\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Área:</label>\n            <input v-model=\"headerConfig.area\" placeholder=\"Administración y Finanzas\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Unidad:</label>\n            <input v-model=\"headerConfig.unidad\" placeholder=\"Tesorería\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Revisión:</label>\n            <input v-model=\"headerConfig.revision\" placeholder=\"(1)\" class=\"header-input\">\n          </div>\n        </div>\n      </div>\n\n      <!-- Secciones editables del contenido -->\n      <div class=\"section\" v-for=\"(section, index) in sections\" :key=\"index\">\n        <h3>{{ section.title }}</h3>\n        <div class=\"section-description\">\n          <p>{{ section.description }}</p>\n        </div>\n        <textarea \n          v-model=\"section.content\" \n          :placeholder=\"section.placeholder\"\n          class=\"section-textarea\"\n          :rows=\"section.rows || 6\"\n        ></textarea>\n      </div>\n\n      <!-- Tabla de procedimiento -->\n      <div class=\"section\">\n        <h3>5. Procedimiento - Tabla de Actividades</h3>\n        <div class=\"section-description\">\n          <p><strong>Instrucciones para la tabla:</strong></p>\n          <ul>\n            <li><strong>Sección principal:</strong> Deja # y Quién vacíos, escribe solo en Actividad</li>\n            <li><strong>Subsección:</strong> Llena solo # y Actividad, deja Quién vacío</li>\n            <li><strong>Fila normal:</strong> Llena las tres columnas</li>\n            <li><strong>Fila vacía:</strong> Para separar, deja las tres columnas vacías</li>\n          </ul>\n        </div>\n        \n        <!-- Vista previa de la tabla -->\n        <div class=\"table-preview\">\n          <h4>Vista Previa de la Tabla:</h4>\n          <div class=\"preview-container\">\n            <table class=\"preview-table\">\n              <thead>\n                <tr>\n                  <th width=\"15%\">(#)</th>\n                  <th width=\"25%\">(Quien)</th>\n                  <th width=\"60%\">(Actividad)</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr v-for=\"(row, index) in procedureTable\" :key=\"index\" \n                    :class=\"getRowClass(row)\">\n                  <td>{{ row.number || '&nbsp;' }}</td>\n                  <td>{{ row.who || '&nbsp;' }}</td>\n                  <td>{{ row.activity || '&nbsp;' }}</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n        \n        <!-- Controles de la tabla -->\n        <div class=\"table-controls\">\n          <button @click=\"addTableRow\" class=\"control-btn add-row\">+ Fila Normal</button>\n          <button @click=\"addTableSection\" class=\"control-btn add-section\">+ Sección</button>\n          <button @click=\"addTableSubsection\" class=\"control-btn add-subsection\">+ Subsección</button>\n          <button @click=\"addEmptyRow\" class=\"control-btn add-empty\">+ Espacio</button>\n        </div>\n        \n        <!-- Editor de la tabla -->\n        <div class=\"table-editor\">\n          <table class=\"editor-table\">\n            <thead>\n              <tr>\n                <th width=\"15%\">#</th>\n                <th width=\"25%\">Quién</th>\n                <th width=\"50%\">Actividad</th>\n                <th width=\"10%\">Acciones</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"(row, index) in procedureTable\" :key=\"index\"\n                  :class=\"getRowClass(row)\">\n                <td>\n                  <input \n                    v-model=\"row.number\" \n                    :placeholder=\"getNumberPlaceholder(row)\" \n                    class=\"table-input\"\n                    :disabled=\"!row.number && !row.who && row.activity\"\n                  >\n                </td>\n                <td>\n                  <input \n                    v-model=\"row.who\" \n                    :placeholder=\"getWhoPlaceholder(row)\" \n                    class=\"table-input\"\n                    :disabled=\"(!row.number && row.activity) || (row.number && !row.who && row.activity)\"\n                  >\n                </td>\n                <td>\n                  <textarea \n                    v-model=\"row.activity\" \n                    :placeholder=\"getActivityPlaceholder(row)\" \n                    class=\"table-textarea\"\n                  ></textarea>\n                </td>\n                <td>\n                  <button \n                    @click=\"removeTableRow(index)\" \n                    class=\"remove-btn\" \n                    :disabled=\"procedureTable.length === 1\"\n                  >\n                    ✕\n                  </button>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { generateWordDocument } from '@/utils/docGenerator'\n\nexport default {\n  name: 'DocumentView',\n  data() {\n    return {\n      headerConfig: {\n        codigo: 'PP-P-PROV-001',\n        area: 'Administración y Finanzas',\n        unidad: 'Tesorería',\n        revision: '(1)'\n      },\n      sections: [\n        // ... (las secciones se mantienen igual)\n      ],\n      procedureTable: [\n        { number: '', who: '', activity: 'Pagos de Compras de Crédito' }\n      ],\n      statusMessage: '',\n      statusType: ''\n    }\n  },\n  methods: {\n    generateWordDocument() {\n      const documentData = {\n        headerConfig: this.headerConfig,\n        objetivo: this.sections[0].content,\n        alcance: this.sections[1].content,\n        responsabilidades: this.sections[2].content,\n        normativa: this.sections[3].content,\n        anexos: this.sections[4].content,\n        terminos: this.sections[5].content,\n        nota: 'Documento generado automáticamente - ASADOS EL CARRETÓN'\n      };\n\n      try {\n        generateWordDocument(documentData, this.procedureTable);\n        this.showStatus('✅ Documento Word generado exitosamente!', 'success');\n      } catch (error) {\n        this.showStatus('❌ Error al generar el documento: ' + error.message, 'error');\n      }\n    },\n    // ... (los demás métodos se mantienen igual)\n  }\n}\n</script>\n\n<style scoped>\n/* ... (estilos anteriores se mantienen) ... */\n\n.header-config {\n  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);\n  border-left: 4px solid #3498db;\n}\n\n.header-fields {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n  gap: 15px;\n  margin-top: 15px;\n}\n\n.field-group {\n  display: flex;\n  flex-direction: column;\n}\n\n.field-group label {\n  font-weight: 600;\n  margin-bottom: 5px;\n  color: #2c3e50;\n  font-size: 0.9rem;\n}\n\n.header-input {\n  padding: 10px 12px;\n  border: 2px solid #e9ecef;\n  border-radius: 6px;\n  font-size: 14px;\n  transition: border-color 0.3s ease;\n}\n\n.header-input:focus {\n  outline: none;\n  border-color: #3498db;\n  box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);\n}\n</style>"],"mappings":"AA6JA,SAASA,oBAAmB,QAAS,sBAAqB;AAE1D,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE;QACZC,MAAM,EAAE,eAAe;QACvBC,IAAI,EAAE,2BAA2B;QACjCC,MAAM,EAAE,WAAW;QACnBC,QAAQ,EAAE;MACZ,CAAC;MACDC,QAAQ,EAAE;QACR;MAAA,CACD;MACDC,cAAc,EAAE,CACd;QAAEC,MAAM,EAAE,EAAE;QAAEC,GAAG,EAAE,EAAE;QAAEC,QAAQ,EAAE;MAA8B,EAChE;MACDC,aAAa,EAAE,EAAE;MACjBC,UAAU,EAAE;IACd;EACF,CAAC;EACDC,OAAO,EAAE;IACPf,oBAAoBA,CAAA,EAAG;MACrB,MAAMgB,YAAW,GAAI;QACnBb,YAAY,EAAE,IAAI,CAACA,YAAY;QAC/Bc,QAAQ,EAAE,IAAI,CAACT,QAAQ,CAAC,CAAC,CAAC,CAACU,OAAO;QAClCC,OAAO,EAAE,IAAI,CAACX,QAAQ,CAAC,CAAC,CAAC,CAACU,OAAO;QACjCE,iBAAiB,EAAE,IAAI,CAACZ,QAAQ,CAAC,CAAC,CAAC,CAACU,OAAO;QAC3CG,SAAS,EAAE,IAAI,CAACb,QAAQ,CAAC,CAAC,CAAC,CAACU,OAAO;QACnCI,MAAM,EAAE,IAAI,CAACd,QAAQ,CAAC,CAAC,CAAC,CAACU,OAAO;QAChCK,QAAQ,EAAE,IAAI,CAACf,QAAQ,CAAC,CAAC,CAAC,CAACU,OAAO;QAClCM,IAAI,EAAE;MACR,CAAC;MAED,IAAI;QACFxB,oBAAoB,CAACgB,YAAY,EAAE,IAAI,CAACP,cAAc,CAAC;QACvD,IAAI,CAACgB,UAAU,CAAC,yCAAyC,EAAE,SAAS,CAAC;MACvE,EAAE,OAAOC,KAAK,EAAE;QACd,IAAI,CAACD,UAAU,CAAC,mCAAkC,GAAIC,KAAK,CAACC,OAAO,EAAE,OAAO,CAAC;MAC/E;IACF;IACA;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}