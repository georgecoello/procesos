-v-a3a988cc>Ejemplo de cómo escribir:</strong></p><pre class=\\\"format-example\\\" data-v-a3a988cc>El proceso comienza cuando el administrador revisa las cuentas por pagar. \\nLuego, elabora una lista con los proveedores y la envía al gerente general. \\nEl gerente general verifica que la información sea correcta. \\nSi todo está bien, continúa con el pago; si encuentra errores, la devuelve para corrección.\\n          </pre></div>\", 2)), _withDirectives(_createElementVNode(\"textarea\", {\n    \"onUpdate:modelValue\": _cache[7] || (_cache[7] = $event => $data.procedimientoText = $event),\n    placeholder: \"Describe el procedimiento completo aquí en párrafos descriptivos...\",\n    class: \"section-textarea\",\n    rows: \"15\"\n  }, null, 512 /* NEED_PATCH */), [[_vModelText, $data.procedimientoText]]), _createCommentVNode(\" Vista previa de la tabla generada automáticamente \"), _createElementVNode(\"div\", _hoisted_16, [_cache[22] || (_cache[22] = _createElementVNode(\"h4\", null, \"Vista Previa de la Tabla Generada Automáticamente:\", -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_17, [_createElementVNode(\"table\", _hoisted_18, [_cache[21] || (_cache[21] = _createElementVNode(\"thead\", null, [_createElementVNode(\"tr\", null, [_createElementVNode(\"th\", {\n    width: \"15%\"\n  }, \"(#)\"), _createElementVNode(\"th\", {\n    width: \"25%\"\n  }, \"(Quien)\"), _createElementVNode(\"th\", {\n    width: \"60%\"\n  }, \"(Actividad)\")])], -1 /* CACHED */)), _createElementVNode(\"tbody\", null, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.generatedTable, (row, index) => {\n    return _openBlock(), _createElementBlock(\"tr\", {\n      key: index,\n      class: _normalizeClass($options.getRowClass(row))\n    }, [_createElementVNode(\"td\", null, _toDisplayString(row.number ? '5.' + row.number : ' '), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(row.who || ' '), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(row.activity || ' '), 1 /* TEXT */)], 2 /* CLASS */);\n  }), 128 /* KEYED_FRAGMENT */))])])])]), _createElementVNode(\"div\", _hoisted_19, [_createElementVNode(\"button\", {\n    onClick: _cache[8] || (_cache[8] = (...args) => $options.parseProcedimiento && $options.parseProcedimiento(...args)),\n    class: \"parse-btn\"\n  }, \" Generar Tabla Automáticamente\"), _createElementVNode(\"button\", {\n    onClick: _cache[9] || (_cache[9] = (...args) => $options.loadExampleProcedimiento && $options.loadExampleProcedimiento(...args)),\n    class: \"sample-btn\"\n  }, \" Cargar Ejemplo Completo\")])]), _createCommentVNode(\" Secciones restantes \"), (_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.remainingSections, (section, index) => {\n    return _openBlock(), _createElementBlock(\"div\", {\n      class: \"section\",\n      key: index + 10\n    }, [_createElementVNode(\"h3\", null, _toDisplayString(section.title), 1 /* TEXT */), _createElementVNode(\"div\", _hoisted_20, [_createElementVNode(\"p\", null, _toDisplayString(section.description), 1 /* TEXT */)]), _withDirectives(_createElementVNode(\"textarea\", {\n      \"onUpdate:modelValue\": $event => section.content = $event,\n      placeholder: section.placeholder,\n      class: \"section-textarea\",\n      rows: section.rows || 6\n    }, null, 8 /* PROPS */, _hoisted_21), [[_vModelText, section.content]])]);\n  }), 128 /* KEYED_FRAGMENT */)), _createElementVNode(\"div\", _hoisted_22, [_createElementVNode(\"button\", {\n    onClick: _cache[10] || (_cache[10] = (...args) => $options.generateWordDocument && $options.generateWordDocument(...args)),\n    class: \"generate-btn\",\n    disabled: $data.isGenerating\n  }, [$data.isGenerating ? (_openBlock(), _createElementBlock(\"span\", _hoisted_24, \"⏳\")) : (_openBlock(), _createElementBlock(\"span\", _hoisted_25, \" Generar Documento Word\"))], 8 /* PROPS */, _hoisted_23), _createElementVNode(\"button\", {\n    onClick: _cache[11] || (_cache[11] = (...args) => $options.resetDocument && $options.resetDocument(...args)),\n    class: \"reset-btn\"\n  }, \" Limpiar Todo \")])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","$data","statusMessage","_normalizeClass","statusType","_createCommentVNode","isGenerating","_hoisted_2","_cache","_createElementVNode","_hoisted_3","_hoisted_4","_hoisted_5","_hoisted_6","headerConfig","manualName","$event","placeholder","_hoisted_7","policyName","_hoisted_8","codigo","_hoisted_9","area","_hoisted_10","unidad","_hoisted_11","revision","_hoisted_12","fecha","type","_Fragment","_renderList","sections","section","index","key","_toDisplayString","title","_hoisted_13","description","content","rows","_hoisted_15","procedimientoText","_hoisted_16","_hoisted_17","_hoisted_18","width","generatedTable","row","$options","getRowClass","number","who","activity","_hoisted_19","onClick","args","parseProcedimiento","loadExampleProcedimiento","remainingSections","_hoisted_20","_hoisted_22","generateWordDocument","disabled","_hoisted_24","_hoisted_25","resetDocument"],"sources":["/home/jorge/Escritorio/Jorge-PC/procesos/procesos/src/views/DocumentView.vue"],"sourcesContent":["<template>\n  <div class=\"document-view\">\n    <div class=\"status-message\" v-if=\"statusMessage\" :class=\"statusType\">\n      {{ statusMessage }}\n    </div>\n\n    <!-- Spinner overlay -->\n    <div v-if=\"isGenerating\" class=\"spinner-overlay\">\n      <div class=\"spinner-content\">\n        <div class=\"spinner\">⏳</div>\n        <p>Generando documento Word...</p>\n      </div>\n    </div>\n\n    <div class=\"document-editor\">\n      <!-- Configuración del Encabezado -->\n      <div class=\"section header-config\">\n        <h3> Configuración del Encabezado del Documento</h3>\n        <div class=\"header-fields\">\n          <div class=\"field-group\">\n            <label>Manual de Políticas y Procedimientos:</label>\n            <input v-model=\"headerConfig.manualName\" placeholder=\"Manual de Políticas y Procedimientos\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>POLÍTICA O PROCEDIMIENTO DE:</label>\n            <input v-model=\"headerConfig.policyName\" placeholder=\"NOMBRE DEL PROCEDIMIENTO\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>CÓDIGO:</label>\n            <input v-model=\"headerConfig.codigo\" placeholder=\"XX-P-XXX-#\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Área:</label>\n            <input v-model=\"headerConfig.area\" placeholder=\"Administración\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Unidad:</label>\n            <input v-model=\"headerConfig.unidad\" placeholder=\"Finanzas\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Revisión:</label>\n            <input v-model=\"headerConfig.revision\" placeholder=\"01\" class=\"header-input\">\n          </div>\n          <div class=\"field-group\">\n            <label>Fecha:</label>\n            <input v-model=\"headerConfig.fecha\" type=\"date\" class=\"header-input\">\n          </div>\n        </div>\n      </div>\n\n      <!-- Secciones editables del contenido -->\n      <div class=\"section\" v-for=\"(section, index) in sections\" :key=\"index\">\n        <h3>{{ section.title }}</h3>\n        <div class=\"section-description\">\n          <p>{{ section.description }}</p>\n        </div>\n        <textarea \n          v-model=\"section.content\" \n          :placeholder=\"section.placeholder\"\n          class=\"section-textarea\"\n          :rows=\"section.rows || 6\"\n        ></textarea>\n      </div>\n\n      <!-- Sección de Procedimiento Mejorada -->\n      <div class=\"section\">\n        <h3>5. Procedimiento</h3>\n        <div class=\"section-description\">\n          <p><strong>Instrucciones para describir el procedimiento:</strong></p>\n          <ul>\n            <li><strong>Escribe en párrafos descriptivos</strong> cómo se realiza el proceso</li>\n            <li><strong>El sistema detectará automáticamente</strong> los responsables y actividades</li>\n            <li><strong>Incluye decisiones y alternativas</strong> de forma natural en el texto</li>\n            <li><strong>El sistema generará automáticamente</strong> la numeración continua (5.1, 5.2, 5.3...)</li>\n            <li><strong>Puedes escribir múltiples párrafos</strong> describiendo diferentes procesos</li>\n          </ul>\n          <p><strong>Ejemplo de cómo escribir:</strong></p>\n          <pre class=\"format-example\">\nEl proceso comienza cuando el administrador revisa las cuentas por pagar. \nLuego, elabora una lista con los proveedores y la envía al gerente general. \nEl gerente general verifica que la información sea correcta. \nSi todo está bien, continúa con el pago; si encuentra errores, la devuelve para corrección.\n          </pre>\n        </div>\n        \n        <textarea \n          v-model=\"procedimientoText\" \n          placeholder=\"Describe el procedimiento completo aquí en párrafos descriptivos...\"\n          class=\"section-textarea\"\n          rows=\"15\"\n        ></textarea>\n        \n        <!-- Vista previa de la tabla generada automáticamente -->\n        <div class=\"table-preview\">\n          <h4>Vista Previa de la Tabla Generada Automáticamente:</h4>\n          <div class=\"preview-container\">\n            <table class=\"preview-table\">\n              <thead>\n                <tr>\n                  <th width=\"15%\">(#)</th>\n                  <th width=\"25%\">(Quien)</th>\n                  <th width=\"60%\">(Actividad)</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr v-for=\"(row, index) in generatedTable\" :key=\"index\" \n                    :class=\"getRowClass(row)\">\n                  <td>{{ row.number ? '5.' + row.number : '&nbsp;' }}</td>\n                  <td>{{ row.who || '&nbsp;' }}</td>\n                  <td>{{ row.activity || '&nbsp;' }}</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n\n        <div class=\"action-buttons\">\n          <button @click=\"parseProcedimiento\" class=\"parse-btn\"> Generar Tabla Automáticamente</button>\n          <button @click=\"loadExampleProcedimiento\" class=\"sample-btn\"> Cargar Ejemplo Completo</button>\n        </div>\n      </div>\n\n      <!-- Secciones restantes -->\n      <div class=\"section\" v-for=\"(section, index) in remainingSections\" :key=\"index + 10\">\n        <h3>{{ section.title }}</h3>\n        <div class=\"section-description\">\n          <p>{{ section.description }}</p>\n        </div>\n        <textarea \n          v-model=\"section.content\" \n          :placeholder=\"section.placeholder\"\n          class=\"section-textarea\"\n          :rows=\"section.rows || 6\"\n        ></textarea>\n      </div>\n      <div class=\"document-controls\">\n      <button @click=\"generateWordDocument\" class=\"generate-btn\" :disabled=\"isGenerating\">\n        <span v-if=\"isGenerating\" class=\"spinner\">⏳</span>\n        <span v-else> Generar Documento Word</span>\n      </button>\n      <button @click=\"resetDocument\" class=\"reset-btn\">\n         Limpiar Todo\n      </button>\n    </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { generateWordDocument } from '@/utils/docGenerator'\n\nexport default {\n  name: 'DocumentView',\n  data() {\n    return {\n      headerConfig: {\n        manualName: 'Manual de Políticas y Procedimientos',\n        policyName: 'PROCEDIMIENTO',\n        codigo: 'XX-P-XXX-#',\n        area: 'Administración',\n        unidad: 'Finanzas',\n        revision: '01',\n        fecha: this.getFormattedDate()\n      },\n      sections: [\n        { \n          title: '1. Objetivo o Propósito', \n          content: '',\n          description: 'Establecer el propósito general del procedimiento.',\n          placeholder: 'Definir el objetivo principal del procedimiento y los resultados esperados...',\n          rows: 4\n        },\n        { \n          title: '2. Alcance', \n          content: '',\n          description: 'Definir los límites y cobertura del procedimiento.',\n          placeholder: 'Especificar los límites, áreas de aplicación y exclusiones del procedimiento...',\n          rows: 4\n        },\n        { \n          title: '3. Responsabilidades', \n          content: '',\n          description: 'Listar los roles y responsabilidades de cada participante.',\n          placeholder: '1. Responsable Principal\\n2. Coordinador\\n3. Ejecutor...',\n          rows: 6\n        },\n        { \n          title: '4. Normativa', \n          content: '',\n          description: 'Establecer las normas, políticas y criterios aplicables.',\n          placeholder: 'I. [MARCO NORMATIVO]\\nEstablecer las normas y políticas que rigen el procedimiento...',\n          rows: 12\n        }\n      ],\n      remainingSections: [\n        { \n          title: '6. Anexos', \n          content: '',\n          description: 'Listar los formatos, documentos y anexos relacionados.',\n          placeholder: 'Formato de registro\\nDocumentos de referencia...',\n          rows: 4\n        },\n        { \n          title: '7. Términos y Referencias', \n          content: '',\n          description: 'Definir términos técnicos y referencias documentales.',\n          placeholder: 'Término 1: Definición\\nTérmino 2: Explicación...',\n          rows: 4\n        }\n      ],\n      procedimientoText: '',\n      generatedTable: [],\n      statusMessage: '',\n      statusType: '',\n      isGenerating: false\n    }\n  },\n  computed: {\n    procedureTable() {\n      return this.generatedTable;\n    }\n  },\n  methods: {\n    getFormattedDate() {\n      const today = new Date();\n      const year = today.getFullYear();\n      const month = String(today.getMonth() + 1).padStart(2, '0');\n      const day = String(today.getDate()).padStart(2, '0');\n      return `${year}-${month}-${day}`;\n    },\n\n    parseProcedimiento() {\n      if (!this.procedimientoText.trim()) {\n        this.showStatus('❌ Por favor ingresa la descripción del procedimiento', 'error');\n        return;\n      }\n\n      try {\n        // Procesar el texto en párrafos\n        const paragraphs = this.procedimientoText.split('\\n\\n').filter(p => p.trim() !== '');\n        const table = [];\n        let stepNumber = 1;\n\n        paragraphs.forEach(paragraph => {\n          const lines = this.processParagraph(paragraph.trim());\n          \n          lines.forEach(line => {\n            if (line.trim()) {\n              const responsible = this.extractResponsible(line);\n              const activity = this.extractActivity(line, responsible);\n              \n              if (responsible || activity) {\n                table.push({ \n                  number: `${stepNumber}`, \n                  who: responsible, \n                  activity: activity \n                });\n                stepNumber++;\n              }\n            }\n          });\n        });\n\n        this.generatedTable = table;\n        this.showStatus(`✅ Tabla generada con ${table.length} actividades detectadas automáticamente`, 'success');\n      } catch (error) {\n        this.showStatus('❌ Error al procesar la descripción: ' + error.message, 'error');\n      }\n    },\n\n    processParagraph(paragraph) {\n      // Dividir el párrafo en oraciones\n      const sentences = paragraph.split(/[.!?]+/).filter(s => s.trim() !== '');\n      const processedLines = [];\n\n      sentences.forEach(sentence => {\n        const trimmedSentence = sentence.trim();\n        if (!trimmedSentence) return;\n\n        // Procesar oraciones condicionales\n        if (trimmedSentence.includes(';') || trimmedSentence.includes('pero') || trimmedSentence.includes('sin embargo')) {\n          // Dividir oraciones compuestas\n          const parts = trimmedSentence.split(/[;]|pero|sin embargo/).filter(p => p.trim() !== '');\n          parts.forEach(part => {\n            processedLines.push(this.cleanSentence(part));\n          });\n        } else if (trimmedSentence.includes('Si ') || trimmedSentence.includes('si ') || \n                   trimmedSentence.includes('Cuando ') || trimmedSentence.includes('cuando ')) {\n          // Procesar condiciones\n          this.processConditionalSentence(trimmedSentence, processedLines);\n        } else {\n          // Oración normal\n          processedLines.push(this.cleanSentence(trimmedSentence));\n        }\n      });\n\n      return processedLines;\n    },\n\n    processConditionalSentence(sentence, processedLines) {\n      const cleanSentence = this.cleanSentence(sentence);\n      \n      // Detectar patrones condicionales comunes\n      if (cleanSentence.includes(' si ') || cleanSentence.startsWith('Si ') || cleanSentence.startsWith('si ')) {\n        // Dividir en condición y consecuencia\n        const conditionalParts = cleanSentence.split(/[,]|;/).filter(p => p.trim() !== '');\n        \n        conditionalParts.forEach(part => {\n          const trimmedPart = part.trim();\n          if (trimmedPart) {\n            processedLines.push(trimmedPart);\n          }\n        });\n      } else {\n        processedLines.push(cleanSentence);\n      }\n    },\n\n    cleanSentence(sentence) {\n      // Limpiar y formatear la oración\n      return sentence\n        .replace(/^[,.\\s]+/, '') // Quitar comas y puntos al inicio\n        .replace(/[,.\\s]+$/, '') // Quitar comas y puntos al final\n        .replace(/\\s+/g, ' ')    // Normalizar espacios\n        .trim();\n    },\n\n    extractResponsible(line) {\n      // Patrones mejorados para detectar responsables en texto descriptivo\n      const patterns = [\n        /^el (\\w+\\s?\\w*)\\s/i,\n        /^la (\\w+\\s?\\w*)\\s/i,\n        /^los (\\w+\\s?\\w*)\\s/i,\n        /^las (\\w+\\s?\\w*)\\s/i,\n        /^un (\\w+\\s?\\w*)\\s/i,\n        /^una (\\w+\\s?\\w*)\\s/i,\n        /^(\\w+\\s?\\w*)\\s(revisa|envía|realiza|verifica|corrige|aprueba|autoriza|elabora|analiza|efectúa|notifica|solicita|confirma)/i,\n        /^(\\w+\\s?\\w*)\\s(recibe|entrega|completa|procede|marca)/i,\n        /(\\w+\\s?\\w*)\\s(revisa|envía|realiza|verifica|corrige|aprueba)/i\n      ];\n\n      for (const pattern of patterns) {\n        const match = line.match(pattern);\n        if (match) {\n          const responsible = match[1] || match[2];\n          if (responsible && !this.isCommonWord(responsible)) {\n            return this.capitalizeFirstLetter(responsible);\n          }\n        }\n      }\n\n      return '';\n    },\n\n    isCommonWord(word) {\n      const commonWords = ['proceso', 'caso', 'pago', 'factura', 'documento', 'lista', 'producto', 'proveedor'];\n      return commonWords.includes(word.toLowerCase());\n    },\n\n    extractActivity(line, responsible) {\n      if (!responsible) return this.capitalizeFirstLetter(line);\n\n      // Remover el responsable del inicio de la línea\n      const patterns = [\n        new RegExp(`^el ${responsible.toLowerCase()}\\\\s+`, 'i'),\n        new RegExp(`^la ${responsible.toLowerCase()}\\\\s+`, 'i'),\n        new RegExp(`^los ${responsible.toLowerCase()}\\\\s+`, 'i'),\n        new RegExp(`^las ${responsible.toLowerCase()}\\\\s+`, 'i'),\n        new RegExp(`^un ${responsible.toLowerCase()}\\\\s+`, 'i'),\n        new RegExp(`^una ${responsible.toLowerCase()}\\\\s+`, 'i'),\n        new RegExp(`^${responsible.toLowerCase()}\\\\s+`, 'i')\n      ];\n\n      let activity = line;\n      for (const pattern of patterns) {\n        activity = activity.replace(pattern, '');\n      }\n\n      return this.capitalizeFirstLetter(activity);\n    },\n\n    capitalizeFirstLetter(string) {\n      if (!string) return '';\n      return string.charAt(0).toUpperCase() + string.slice(1);\n    },\n\n    loadExampleProcedimiento() {\n      this.procedimientoText = `En el proceso de pagos de compras a crédito, el administrador o administradora es quien inicia la gestión revisando las cuentas por pagar que están próximas a vencer, para identificar a qué proveedores se les debe realizar el pago. Luego, el mismo administrador elabora una lista de proveedores con el monto total adeudado y la envía al gerente general para su revisión y aprobación. El gerente general recibe el documento denominado “Lista de Pago a Proveedores” y lo examina cuidadosamente. Si considera que la información es correcta, continúa con el proceso; pero si encuentra algún error, devuelve el formato al administrador o administradora para que realice las correcciones necesarias.\n\nUna vez que la lista ha sido aprobada, el gerente general realiza los pagos correspondientes de las facturas, utilizando los medios disponibles, como transferencia bancaria, pago electrónico, link de pago o tarjeta de crédito. Después de realizar los pagos, el gerente general envía a la administración los comprobantes de pago e imprime los recibos correspondientes. Finalmente, el administrador o administradora registra la cancelación de los pagos en el sistema contable, lo que marca el fin del proceso de compras a crédito.\n\nEn cuanto a los pagos de contado en efectivo, el proceso comienza cuando el proveedor entrega la factura al jefe de restaurante. El jefe de restaurante revisa la factura detenidamente, verificando las cantidades, los detalles del producto y los precios. Si el jefe de restaurante detecta errores en la factura, la devuelve al proveedor para su corrección y se repite el paso correspondiente. En cambio, si la factura está correcta, el jefe de restaurante efectúa el pago en efectivo utilizando los fondos disponibles en caja. Posteriormente, el jefe de restaurante envía la factura pagada al área de administración, con lo cual el proceso finaliza.\n\nPor último, en los pagos por transferencia electrónica, link de pago o tarjeta, el procedimiento inicia cuando el proveedor entrega la factura de compra junto con el pedido. El encargado o encargada de almacén recibe ambos y, una vez confirmada la recepción del producto, notifica al gerente general que el pedido ha llegado y solicita la cancelación total de la factura. Luego, el gerente general revisa cuidadosamente el nombre del proveedor y los datos de la cuenta bancaria proporcionada, para asegurarse de que la información sea correcta antes de realizar la transferencia.\n\nTras verificar los datos, el gerente general efectúa el pago mediante transferencia o el método acordado, y envía al encargado o encargada de almacén el comprobante de pago correspondiente. Finalmente, el proveedor confirma que la transferencia o el pago se haya realizado exitosamente, dando por concluido el proceso de pago.`;\n\n      this.showStatus('📝 Ejemplo completo cargado. Haz clic en \"Generar Tabla Automáticamente\" para ver el resultado.', 'info');\n    },\n\n    getRowClass(row) {\n      if (!row.number && !row.who && row.activity) {\n        return 'section-row';\n      }\n      return 'normal-row';\n    },\n\n    async generateWordDocument() {\n      this.isGenerating = true;\n      \n      // Asegurarse de que la tabla esté actualizada\n      if (this.procedimientoText && this.generatedTable.length === 0) {\n        this.parseProcedimiento();\n      }\n\n      const documentData = {\n        headerConfig: this.headerConfig,\n        objetivo: this.sections[0].content,\n        alcance: this.sections[1].content,\n        responsabilidades: this.sections[2].content,\n        normativa: this.sections[3].content,\n        anexos: this.remainingSections[0].content,\n        terminos: this.remainingSections[1].content\n      };\n\n      try {\n        await generateWordDocument(documentData, this.generatedTable);\n        this.showStatus('✅ Documento Word generado exitosamente! El encabezado aparecerá en todas las páginas.', 'success');\n      } catch (error) {\n        this.showStatus('❌ Error al generar el documento: ' + error.message, 'error');\n      } finally {\n        this.isGenerating = false;\n      }\n    },\n\n    resetDocument() {\n      if (confirm('¿Estás seguro de que quieres limpiar todo el documento? Se perderán todos los cambios.')) {\n        this.sections.forEach(section => {\n          section.content = '';\n        });\n        this.remainingSections.forEach(section => {\n          section.content = '';\n        });\n        this.procedimientoText = '';\n        this.generatedTable = [];\n        this.headerConfig.fecha = this.getFormattedDate();\n        // Restablecer valores por defecto\n        this.headerConfig.manualName = 'Manual de Políticas y Procedimientos';\n        this.headerConfig.policyName = 'PROCEDIMIENTO';\n        this.headerConfig.codigo = 'XX-P-XXX-#';\n        this.headerConfig.area = 'Administración';\n        this.headerConfig.unidad = 'Finanzas';\n        this.headerConfig.revision = '01';\n        this.showStatus('🗑️ Todo el contenido ha sido resetado', 'info');\n      }\n    },\n\n    showStatus(message, type) {\n      this.statusMessage = message;\n      this.statusType = type;\n      \n      setTimeout(() => {\n        this.statusMessage = '';\n        this.statusType = '';\n      }, 5000);\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* Los estilos se mantienen igual que en tu código original */\n.document-view {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 20px;\n  font-family: 'Times New Roman', serif;\n}\n\n.document-controls {\n  display: flex;\n  gap: 15px;\n  margin-bottom: 30px;\n  justify-content: center;\n  flex-wrap: wrap;\n}\n\n.generate-btn, .reset-btn {\n  border: none;\n  padding: 12px 24px;\n  border-radius: 6px;\n  cursor: pointer;\n  font-size: 14px;\n  font-weight: 600;\n  transition: all 0.3s ease;\n  min-width: 160px;\n  font-family: 'Times New Roman', s