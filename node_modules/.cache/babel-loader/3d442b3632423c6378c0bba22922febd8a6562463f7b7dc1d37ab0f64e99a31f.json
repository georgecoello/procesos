{"ast":null,"code":"export default {\n  name: 'DocumentSection',\n  props: {\n    title: {\n      type: String,\n      required: true\n    },\n    content: {\n      type: String,\n      default: ''\n    }\n  },\n  data() {\n    return {\n      isEditing: false,\n      localContent: this.content\n    };\n  },\n  computed: {\n    formattedContent() {\n      return this.localContent || `<em>No hay contenido para ${this.title}. Haz clic en Editar para agregar información.</em>`;\n    }\n  },\n  methods: {\n    toggleEdit() {\n      if (this.isEditing) {\n        this.$emit('update:content', this.localContent);\n      }\n      this.isEditing = !this.isEditing;\n    }\n  },\n  watch: {\n    content(newVal) {\n      this.localContent = newVal;\n    }\n  }\n};","map":{"version":3,"names":["name","props","title","type","String","required","content","default","data","isEditing","localContent","computed","formattedContent","methods","toggleEdit","$emit","watch","newVal"],"sources":["/home/jorge/Escritorio/Jorge-PC/procesos/procesos/src/components/DocumentSection.vue"],"sourcesContent":["<template>\n  <div class=\"document-section\">\n    <div class=\"section-header\">\n      <h3>{{ title }}</h3>\n      <button @click=\"toggleEdit\" class=\"edit-btn\">\n        {{ isEditing ? 'Guardar' : 'Editar' }}\n      </button>\n    </div>\n    \n    <div class=\"section-content\">\n      <template v-if=\"isEditing\">\n        <textarea \n          v-model=\"localContent\" \n          class=\"edit-textarea\"\n          :placeholder=\"`Escribe el contenido para ${title}...`\"\n        ></textarea>\n      </template>\n      <template v-else>\n        <div class=\"content-display\" v-html=\"formattedContent\"></div>\n      </template>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'DocumentSection',\n  props: {\n    title: {\n      type: String,\n      required: true\n    },\n    content: {\n      type: String,\n      default: ''\n    }\n  },\n  data() {\n    return {\n      isEditing: false,\n      localContent: this.content\n    }\n  },\n  computed: {\n    formattedContent() {\n      return this.localContent || `<em>No hay contenido para ${this.title}. Haz clic en Editar para agregar información.</em>`;\n    }\n  },\n  methods: {\n    toggleEdit() {\n      if (this.isEditing) {\n        this.$emit('update:content', this.localContent);\n      }\n      this.isEditing = !this.isEditing;\n    }\n  },\n  watch: {\n    content(newVal) {\n      this.localContent = newVal;\n    }\n  }\n}\n</script>\n\n<style scoped>\n.document-section {\n  border: 1px solid #ddd;\n  border-radius: 8px;\n  margin-bottom: 20px;\n  overflow: hidden;\n}\n\n.section-header {\n  background-color: #3498db;\n  color: white;\n  padding: 15px 20px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.section-header h3 {\n  margin: 0;\n  font-size: 1.2rem;\n}\n\n.edit-btn {\n  background-color: rgba(255, 255, 255, 0.2);\n  color: white;\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  padding: 5px 15px;\n  border-radius: 4px;\n  cursor: pointer;\n  transition: background-color 0.3s;\n}\n\n.edit-btn:hover {\n  background-color: rgba(255, 255, 255, 0.3);\n}\n\n.section-content {\n  padding: 20px;\n}\n\n.edit-textarea {\n  width: 100%;\n  min-height: 150px;\n  padding: 10px;\n  border: 1px solid #ddd;\n  border-radius: 4px;\n  font-family: inherit;\n  font-size: 14px;\n  resize: vertical;\n}\n\n.content-display {\n  line-height: 1.6;\n  white-space: pre-wrap;\n}\n</style>"],"mappings":"AAyBA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACLC,KAAK,EAAE;MACLC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ,CAAC;IACDC,OAAO,EAAE;MACPH,IAAI,EAAEC,MAAM;MACZG,OAAO,EAAE;IACX;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,KAAK;MAChBC,YAAY,EAAE,IAAI,CAACJ;IACrB;EACF,CAAC;EACDK,QAAQ,EAAE;IACRC,gBAAgBA,CAAA,EAAG;MACjB,OAAO,IAAI,CAACF,YAAW,IAAK,6BAA6B,IAAI,CAACR,KAAK,qDAAqD;IAC1H;EACF,CAAC;EACDW,OAAO,EAAE;IACPC,UAAUA,CAAA,EAAG;MACX,IAAI,IAAI,CAACL,SAAS,EAAE;QAClB,IAAI,CAACM,KAAK,CAAC,gBAAgB,EAAE,IAAI,CAACL,YAAY,CAAC;MACjD;MACA,IAAI,CAACD,SAAQ,GAAI,CAAC,IAAI,CAACA,SAAS;IAClC;EACF,CAAC;EACDO,KAAK,EAAE;IACLV,OAAOA,CAACW,MAAM,EAAE;MACd,IAAI,CAACP,YAAW,GAAIO,MAAM;IAC5B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}