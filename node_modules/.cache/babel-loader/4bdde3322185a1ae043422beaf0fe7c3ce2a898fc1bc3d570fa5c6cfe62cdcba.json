{"ast":null,"code":"export default {\n  name: 'BulletList',\n  props: {\n    items: {\n      type: Array,\n      required: true\n    },\n    bulletType: {\n      type: String,\n      default: 'disc',\n      validator: value => ['disc', 'circle', 'square', 'check', 'star'].includes(value)\n    }\n  }\n};","map":{"version":3,"names":["name","props","items","type","Array","required","bulletType","String","default","validator","value","includes"],"sources":["/home/jorge/Escritorio/Jorge-PC/procesos/procesos/src/views/DocumentView.vue"],"sourcesContent":["<template>\n  <ul :class=\"['bullet-list', bulletType]\">\n    <li v-for=\"(item, index) in items\" :key=\"index\">\n      {{ item }}\n    </li>\n  </ul>\n</template>\n\n<script>\nexport default {\n  name: 'BulletList',\n  props: {\n    items: {\n      type: Array,\n      required: true\n    },\n    bulletType: {\n      type: String,\n      default: 'disc',\n      validator: (value) => ['disc', 'circle', 'square', 'check', 'star'].includes(value)\n    }\n  }\n}\n</script>\n\n<style scoped>\n.bullet-list {\n  list-style-type: disc;\n  padding-left: 20px;\n}\n\n.bullet-list.circle {\n  list-style-type: circle;\n}\n\n.bullet-list.square {\n  list-style-type: square;\n}\n\n.bullet-list.check li::before {\n  content: \"✓ \";\n  color: #4CAF50;\n  font-weight: bold;\n}\n\n.bullet-list.star li::before {\n  content: \"★ \";\n  color: #FFD700;\n}\n\n.bullet-list li {\n  margin-bottom: 8px;\n  line-height: 1.5;\n}\n</style>"],"mappings":"AASA,eAAe;EACbA,IAAI,EAAE,YAAY;EAClBC,KAAK,EAAE;IACLC,KAAK,EAAE;MACLC,IAAI,EAAEC,KAAK;MACXC,QAAQ,EAAE;IACZ,CAAC;IACDC,UAAU,EAAE;MACVH,IAAI,EAAEI,MAAM;MACZC,OAAO,EAAE,MAAM;MACfC,SAAS,EAAGC,KAAK,IAAK,CAAC,MAAM,EAAE,QAAQ,EAAE,QAAQ,EAAE,OAAO,EAAE,MAAM,CAAC,CAACC,QAAQ,CAACD,KAAK;IACpF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}