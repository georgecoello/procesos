{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nexport default {\n  name: \"DocumentView\",\n  data() {\n    return {\n      sections: [{\n        title: \"1. Introducción\",\n        description: \"Descripción general de la introducción...\",\n        placeholder: \"Escribe aquí la introducción...\",\n        content: \"\",\n        rows: 4\n      }, {\n        title: \"2. Alcance\",\n        description: \"Define el alcance del documento...\",\n        placeholder: \"Describe el alcance...\",\n        content: \"\",\n        rows: 4\n      }, {\n        title: \"3. Objetivos\",\n        description: \"Indica los objetivos principales...\",\n        placeholder: \"Lista los objetivos...\",\n        content: \"\",\n        rows: 4\n      }, {\n        title: \"4. Normativa\",\n        description: \"Incluye normas, requisitos y disposiciones…\",\n        placeholder: \"Agrega la normativa aquí...\",\n        content: \"\",\n        rows: 6\n      }]\n    };\n  },\n  methods: {\n    applyWordNumbering(index) {\n      let text = this.sections[index].content || \"\";\n\n      // Aplicar numeración línea por línea\n      const numbered = text.split(\"\\n\").map((line, i) => `${i + 1}. ${line}`).join(\"\\n\");\n      this.sections[index].content = numbered;\n    }\n  }\n};","map":{"version":3,"names":["name","data","sections","title","description","placeholder","content","rows","methods","applyWordNumbering","index","text","numbered","split","map","line","i","join"],"sources":["/home/jorge/Escritorio/Jorge-PC/procesos/procesos/src/views/DocumentView.vue"],"sourcesContent":["<template>\n  <div class=\"document-container\">\n    <div class=\"header\">\n      <h2>Documento</h2>\n    </div>\n\n    <div class=\"sections-container\">\n      <div\n        class=\"section\"\n        v-for=\"(section, index) in sections\"\n        :key=\"index\"\n      >\n        <h3>{{ section.title }}</h3>\n\n        <div class=\"section-description\">\n          <p>{{ section.description }}</p>\n        </div>\n\n        <!-- Botón solo para la sección 4. Normativa -->\n        <button\n          v-if=\"section.title === '4. Normativa'\"\n          class=\"numbering-btn\"\n          @click=\"applyWordNumbering(index)\"\n        >\n          🔢 Numerar estilo Word\n        </button>\n\n        <textarea\n          v-model=\"section.content\"\n          :placeholder=\"section.placeholder\"\n          :rows=\"section.rows\"\n        ></textarea>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"DocumentView\",\n\n  data() {\n    return {\n      sections: [\n        {\n          title: \"1. Introducción\",\n          description: \"Descripción general de la introducción...\",\n          placeholder: \"Escribe aquí la introducción...\",\n          content: \"\",\n          rows: 4,\n        },\n        {\n          title: \"2. Alcance\",\n          description: \"Define el alcance del documento...\",\n          placeholder: \"Describe el alcance...\",\n          content: \"\",\n          rows: 4,\n        },\n        {\n          title: \"3. Objetivos\",\n          description: \"Indica los objetivos principales...\",\n          placeholder: \"Lista los objetivos...\",\n          content: \"\",\n          rows: 4,\n        },\n        {\n          title: \"4. Normativa\",\n          description: \"Incluye normas, requisitos y disposiciones…\",\n          placeholder: \"Agrega la normativa aquí...\",\n          content: \"\",\n          rows: 6,\n        },\n      ],\n    };\n  },\n\n  methods: {\n    applyWordNumbering(index) {\n      let text = this.sections[index].content || \"\";\n\n      // Aplicar numeración línea por línea\n      const numbered = text\n        .split(\"\\n\")\n        .map((line, i) => `${i + 1}. ${line}`)\n        .join(\"\\n\");\n\n      this.sections[index].content = numbered;\n    },\n  },\n};\n</script>\n\n<style scoped>\n.document-container {\n  padding: 20px;\n}\n\n.section {\n  margin-bottom: 25px;\n  background: #f9f9f9;\n  padding: 15px;\n  border-radius: 8px;\n}\n\ntextarea {\n  width: 100%;\n  resize: vertical;\n  padding: 10px;\n  border-radius: 6px;\n  border: 1px solid #ccc;\n  outline: none;\n}\n\n.numbering-btn {\n  margin-bottom: 10px;\n  padding: 6px 12px;\n  background: #0078ff;\n  color: white;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  font-size: 14px;\n}\n\n.numbering-btn:hover {\n  background: #005fcc;\n}\n</style>\n"],"mappings":";;AAsCA,eAAe;EACbA,IAAI,EAAE,cAAc;EAEpBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,CACR;QACEC,KAAK,EAAE,iBAAiB;QACxBC,WAAW,EAAE,2CAA2C;QACxDC,WAAW,EAAE,iCAAiC;QAC9CC,OAAO,EAAE,EAAE;QACXC,IAAI,EAAE;MACR,CAAC,EACD;QACEJ,KAAK,EAAE,YAAY;QACnBC,WAAW,EAAE,oCAAoC;QACjDC,WAAW,EAAE,wBAAwB;QACrCC,OAAO,EAAE,EAAE;QACXC,IAAI,EAAE;MACR,CAAC,EACD;QACEJ,KAAK,EAAE,cAAc;QACrBC,WAAW,EAAE,qCAAqC;QAClDC,WAAW,EAAE,wBAAwB;QACrCC,OAAO,EAAE,EAAE;QACXC,IAAI,EAAE;MACR,CAAC,EACD;QACEJ,KAAK,EAAE,cAAc;QACrBC,WAAW,EAAE,6CAA6C;QAC1DC,WAAW,EAAE,6BAA6B;QAC1CC,OAAO,EAAE,EAAE;QACXC,IAAI,EAAE;MACR,CAAC;IAEL,CAAC;EACH,CAAC;EAEDC,OAAO,EAAE;IACPC,kBAAkBA,CAACC,KAAK,EAAE;MACxB,IAAIC,IAAG,GAAI,IAAI,CAACT,QAAQ,CAACQ,KAAK,CAAC,CAACJ,OAAM,IAAK,EAAE;;MAE7C;MACA,MAAMM,QAAO,GAAID,IAAG,CACjBE,KAAK,CAAC,IAAI,EACVC,GAAG,CAAC,CAACC,IAAI,EAAEC,CAAC,KAAK,GAAGA,CAAA,GAAI,CAAC,KAAKD,IAAI,EAAE,EACpCE,IAAI,CAAC,IAAI,CAAC;MAEb,IAAI,CAACf,QAAQ,CAACQ,KAAK,CAAC,CAACJ,OAAM,GAAIM,QAAQ;IACzC;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}