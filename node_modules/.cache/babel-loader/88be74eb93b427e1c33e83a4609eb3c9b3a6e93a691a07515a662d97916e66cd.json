_hoisted_15, [_createElementVNode(\"div\", _hoisted_16, [_cache[20] || (_cache[20] = _createElementVNode(\"strong\", null, \"Caracteres:\", -1 /* CACHED */)), _createTextVNode(\" \" + _toDisplayString($options.characterCount), 1 /* TEXT */)]), _createElementVNode(\"div\", _hoisted_17, [_cache[21] || (_cache[21] = _createElementVNode(\"strong\", null, \"Palabras:\", -1 /* CACHED */)), _createTextVNode(\" \" + _toDisplayString($options.wordCount), 1 /* TEXT */)]), _createElementVNode(\"div\", _hoisted_18, [_cache[22] || (_cache[22] = _createElementVNode(\"strong\", null, \"Modo:\", -1 /* CACHED */)), _createElementVNode(\"span\", {\n    class: _normalizeClass($setup.editor?.isActive('bulletList') ? 'active-mode' : '')\n  }, _toDisplayString($setup.editor?.isActive('bulletList') ? 'Viñetas Activadas' : 'Texto Normal'), 3 /* TEXT, CLASS */)])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_createCommentVNode","$setup","editor","_hoisted_2","_hoisted_3","onClick","_cache","$event","chain","focus","toggleBold","run","_normalizeClass","isActive","title","toggleItalic","toggleStrike","_hoisted_4","toggleBulletList","toggleOrderedList","_hoisted_5","setParagraph","toggleHeading","level","_hoisted_6","setTextAlign","textAlign","_hoisted_7","args","$options","undo","redo","clearContent","_hoisted_8","_createVNode","_component_editor_content","_hoisted_9","_hoisted_10","copyHTML","_hoisted_11","_toDisplayString","htmlContent","_hoisted_12","_hoisted_13","_Fragment","_renderList","$data","quickExamples","example","key","name","loadExample","content","_hoisted_14","_hoisted_15","_hoisted_16","characterCount","_hoisted_17","wordCount","_hoisted_18"],"sources":["/home/jorge/Escritorio/Jorge-PC/procesos/procesos/src/views/DocumentView.vue"],"sourcesContent":["<template>\n  <div class=\"tiptap-editor-container\">\n    <div class=\"header\">\n      <h1>✏️ Editor TipTap con Viñetas</h1>\n      <p>Editor de texto enriquecido estilo Word</p>\n    </div>\n\n    <!-- Barra de herramientas -->\n    <div v-if=\"editor\" class=\"menu-bar\">\n      <div class=\"tool-group\">\n        <button \n          @click=\"editor.chain().focus().toggleBold().run()\" \n          :class=\"{ 'is-active': editor.isActive('bold') }\"\n          title=\"Negrita\"\n        >\n          <strong>B</strong>\n        </button>\n        <button \n          @click=\"editor.chain().focus().toggleItalic().run()\" \n          :class=\"{ 'is-active': editor.isActive('italic') }\"\n          title=\"Cursiva\"\n        >\n          <em>I</em>\n        </button>\n        <button \n          @click=\"editor.chain().focus().toggleStrike().run()\" \n          :class=\"{ 'is-active': editor.isActive('strike') }\"\n          title=\"Tachado\"\n        >\n          <s>S</s>\n        </button>\n      </div>\n\n      <div class=\"tool-group\">\n        <button \n          @click=\"editor.chain().focus().toggleBulletList().run()\" \n          :class=\"{ 'is-active': editor.isActive('bulletList') }\"\n          title=\"Lista con viñetas\"\n        >\n          • Lista\n        </button>\n        <button \n          @click=\"editor.chain().focus().toggleOrderedList().run()\" \n          :class=\"{ 'is-active': editor.isActive('orderedList') }\"\n          title=\"Lista numerada\"\n        >\n          1. Lista\n        </button>\n      </div>\n\n      <div class=\"tool-group\">\n        <button \n          @click=\"editor.chain().focus().setParagraph().run()\" \n          :class=\"{ 'is-active': editor.isActive('paragraph') }\"\n          title=\"Párrafo normal\"\n        >\n          P\n        </button>\n        <button \n          @click=\"editor.chain().focus().toggleHeading({ level: 1 }).run()\" \n          :class=\"{ 'is-active': editor.isActive('heading', { level: 1 }) }\"\n          title=\"Título 1\"\n        >\n          H1\n        </button>\n        <button \n          @click=\"editor.chain().focus().toggleHeading({ level: 2 }).run()\" \n          :class=\"{ 'is-active': editor.isActive('heading', { level: 2 }) }\"\n          title=\"Título 2\"\n        >\n          H2\n        </button>\n      </div>\n\n      <div class=\"tool-group\">\n        <button \n          @click=\"editor.chain().focus().setTextAlign('left').run()\" \n          :class=\"{ 'is-active': editor.isActive({ textAlign: 'left' }) }\"\n          title=\"Alinear izquierda\"\n        >\n          ⬅\n        </button>\n        <button \n          @click=\"editor.chain().focus().setTextAlign('center').run()\" \n          :class=\"{ 'is-active': editor.isActive({ textAlign: 'center' }) }\"\n          title=\"Centrar\"\n        >\n          ⬤\n        </button>\n        <button \n          @click=\"editor.chain().focus().setTextAlign('right').run()\" \n          :class=\"{ 'is-active': editor.isActive({ textAlign: 'right' }) }\"\n          title=\"Alinear derecha\"\n        >\n          ➡\n        </button>\n      </div>\n\n      <div class=\"tool-group\">\n        <button @click=\"undo\" title=\"Deshacer\">\n          ↶\n        </button>\n        <button @click=\"redo\" title=\"Rehacer\">\n          ↷\n        </button>\n        <button @click=\"clearContent\" class=\"clear-btn\" title=\"Limpiar todo\">\n          🗑️\n        </button>\n      </div>\n    </div>\n\n    <!-- Editor TipTap -->\n    <div class=\"editor-container\">\n      <editor-content :editor=\"editor\" class=\"editor\" />\n    </div>\n\n    <!-- Vista previa HTML -->\n    <div class=\"preview-section\">\n      <div class=\"preview-header\">\n        <h3>👁️ Vista Previa HTML</h3>\n        <button @click=\"copyHTML\" class=\"copy-btn\">\n          📋 Copiar HTML\n        </button>\n      </div>\n      <div class=\"html-preview\">\n        <pre>{{ htmlContent }}</pre>\n      </div>\n    </div>\n\n    <!-- Ejemplos rápidos -->\n    <div class=\"examples-section\">\n      <h3>💡 Plantillas Rápidas</h3>\n      <div class=\"example-buttons\">\n        <button \n          v-for=\"example in quickExamples\" \n          :key=\"example.name\"\n          @click=\"loadExample(example.content)\"\n          class=\"example-btn\"\n        >\n          {{ example.name }}\n        </button>\n      </div>\n    </div>\n\n    <!-- Información del editor -->\n    <div class=\"editor-info\">\n      <div class=\"info-item\">\n        <strong>Caracteres:</strong> {{ characterCount }}\n      </div>\n      <div class=\"info-item\">\n        <strong>Palabras:</strong> {{ wordCount }}\n      </div>\n      <div class=\"info-item\">\n        <strong>Modo:</strong> \n        <span :class=\"editor?.isActive('bulletList') ? 'active-mode' : ''\">\n          {{ editor?.isActive('bulletList') ? 'Viñetas Activadas' : 'Texto Normal' }}\n        </span>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { useEditor, EditorContent } from '@tiptap/vue-3'\nimport StarterKit from '@tiptap/starter-kit'\nimport BulletList from '@tiptap/extension-bullet-list'\nimport OrderedList from '@tiptap/extension-ordered-list'\nimport ListItem from '@tiptap/extension-list-item'\nimport TextAlign from '@tiptap/extension-text-align'\n\nexport default {\n  name: 'TiptapEditor',\n  components: {\n    EditorContent,\n  },\n  setup() {\n    const editor = useEditor({\n      content: `\n        <h2>¡Bienvenido al Editor TipTap!</h2>\n        <p>Este es un editor de texto enriquecido con soporte para:</p>\n        <ul>\n          <li><strong>Viñetas</strong> y listas numeradas</li>\n          <li><em>Texto en cursiva</em> y <strong>negrita</strong></li>\n          <li>Diferentes niveles de <s>encabezados</s></li>\n          <li>Alineación de texto</li>\n        </ul>\n        <p>¡Prueba las diferentes funcionalidades!</p>\n      `,\n      extensions: [\n        StarterKit,\n        BulletList,\n        OrderedList,\n        ListItem,\n        TextAlign.configure({\n          types: ['heading', 'paragraph'],\n        }),\n      ],\n      editorProps: {\n        attributes: {\n          class: 'prose focus:outline-none max-w-none',\n        },\n      },\n    })\n\n    return { editor }\n  },\n  data() {\n    return {\n      quickExamples: [\n        {\n          name: 'Lista de Tareas',\n          content: `\n            <h3>Lista de Tareas Pendientes</h3>\n            <ul>\n              <li>Revisar correos electrónicos</li>\n              <li>Preparar presentación mensual</li>\n              <li>Reunión con el equipo de desarrollo</li>\n              <li>Actualizar documentación</li>\n            </ul>\n          `\n        },\n        {\n          name: 'Notas de Reunión',\n          content: `\n            <h2>Resumen de Reunión</h2>\n            <h3>Puntos tratados:</h3>\n            <ol>\n              <li>Revisión de objetivos trimestrales</li>\n              <li>Presentación de nuevos proyectos</li>\n              <li>Asignación de recursos</li>\n            </ol>\n            <h3>Acciones:</h3>\n            <ul>\n              <li><strong>Juan:</strong> Preparar informe financiero</li>\n              <li><strong>María:</strong> Contactar con proveedores</li>\n              <li><strong>Carlos:</strong> Desarrollar prototipo</li>\n            </ul>\n          `\n        },\n        {\n          name: 'Ideas de Proyecto',\n          content: `\n            <h1>Ideas para Nuevo Proyecto</h1>\n            <ul>\n              <li>\n                <strong>App móvil:</strong> \n                <ul>\n                  <li>Interfaz intuitiva</li>\n                  <li>Sincronización en la nube</li>\n                  <li>Notificaciones push</li>\n                </ul>\n              </li>\n              <li>\n                <strong>Plataforma web:</strong>\n                <ul>\n                  <li>Diseño responsive</li>\n                  <li>Integración con APIs</li>\n                  <li>Panel de administración</li>\n                </ul>\n              </li>\n            </ul>\n          `\n        }\n      ]\n    }\n  },\n  computed: {\n    htmlContent() {\n      return this.editor?.getHTML() || ''\n    },\n    characterCount() {\n      return this.editor?.storage.characterCount?.characters() || 0\n    },\n    wordCount() {\n      return this.editor?.storage.characterCount?.words() || 0\n    }\n  },\n  methods: {\n    undo() {\n      this.editor?.commands.undo()\n    },\n    redo() {\n      this.editor?.commands.redo()\n    },\n    clearContent() {\n      this.editor?.commands.clearContent()\n    },\n    copyHTML() {\n      navigator.clipboard.writeText(this.htmlContent).then(() => {\n        alert('HTML copiado al portapapeles!')\n      })\n    },\n    loadExample(content) {\n      this.editor?.commands.setContent(content)\n    }\n  },\n  beforeUnmount() {\n    this.editor?.destroy()\n  }\n}\n</script>\n\n<style scoped>\n.tiptap-editor-container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 20px;\n  font-family: 'Segoe UI', system-ui, sans-serif;\n}\n\n.header {\n  text-align: center;\n  margin-bottom: 30px;\n  background: linear-gradient(135deg, #667eea, #764ba2);\n  color: white;\n  padding: 30px;\n  border-radius: 15px;\n}\n\n.header h1 {\n  margin: 0 0 10px 0;\n  font-size: 2.5em;\n}\n\n.header p {\n  margin: 0;\n  opacity: 0.9;\n  font-size: 1.1em;\n}\n\n.menu-bar {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  padding: 15px;\n  background: #f8f9fa;\n  border-radius: 10px;\n  margin-bottom: 20px;\n  border: 2px solid #e9ecef;\n}\n\n.tool-group {\n  display: flex;\n  gap: 5px;\n  padding: 5px;\n  background: white;\n  border-radius: 8px;\n  border: 1px solid #dee2e6;\n}\n\n.menu-bar button {\n  padding: 8px 12px;\n  border: none;\n  background: white;\n  border-radius: 6px;\n  cursor: pointer;\n  transition: all 0.2s;\n  font-size: 14px;\n  border: 1px solid transparent;\n}\n\n.menu-bar button:hover {\n  background: #007bff;\n  color: white;\n  transform: translateY(-1px);\n}\n\n.menu-bar button.is-active {\n  background: #007bff;\n  color: white;\n  border-color: #0056b3;\n}\n\n.clear-btn {\n  background: #dc3545 !important;\n  color: white !important;\n}\n\n.clear-btn:hover {\n  background: #c82333 !important;\n}\n\n.editor-container {\n  border: 2px solid #e9ecef;\n  border-radius: 10px;\n  overflow: hidden;\n  margin-bottom: 20px;\n  background: white;\n}\n\n.editor {\n  padding: 20px;\n  min-height: 400px;\n  max-height: 600px;\n  overflow-y: auto;\n}\n\n.preview-section {\n  background: #f8f9fa;\n  border-radius: 10px;\n  padding: 20px;\n  margin-bottom: 20px;\n}\n\n.preview-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 15px;\n}\n\n.preview-header h3 {\n  margin: 0;\n  color: #495057;\n}\n\n.copy-btn {\n  padding: 8px 15px;\n  background: #28a745;\n  color: white;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  transition: background 0.2s;\n}\n\n.copy-btn:hover {\n  background: #218838;\n}\n\n.html-preview {\n  background: #2d3748;\n  color: #e2e8f0;\n  padding: 15px;\n  border-radius: 8px;\n  overflow-x: auto;\n  font-family: 'Courier New', monospace;\n  font-size: 14px;\n}\n\n.examples-section {\n  background: white;\n  padding: 20px;\n  border-radius: 10px;\n  border: 2px solid #e9ecef;\n  margin-bottom: 20px;\n}\n\n.examples-section h3 {\n  margin: 0 0 15px 0;\n  color: #495057;\n}\n\n.example-buttons {\n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n}\n\n.example-btn {\n  padding: 10px 15px;\n  background: #6c757d;\n  color: white;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.example-btn:hover {\n  background: #545b62;\n  transform: translateY(-1px);\n}\n\n.editor-info {\n  display: flex;\n  gap: 20px;\n  padding: 15px;\n  background: #e9ecef;\n  border-radius: 10px;\n  font-size: 14px;\n}\n\n.info-item {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n}\n\n.active-mode {\n  color: #28a745;\n  font-weight: bold;\n}\n\n/* Estilos para el contenido del editor */\n:deep(.ProseMirror